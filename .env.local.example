# Copy this file to .env.local and fill in real values.
# .env.local is gitignored -- never commit real secrets.
#
# None of these are VITE_-prefixed on purpose: Vite inlines any VITE_*
# variable into the JS bundle shipped to every visitor's browser. These are
# only ever read inside api/* serverless functions, server-side.

# Required: Gemini API key (server-side only). Get one from
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: Gemini model override (defaults to gemini-2.5-flash if unset).
GEMINI_MODEL=

# Required: Supabase project URL, e.g. https://xxxxx.supabase.co
SUPABASE_URL=

# Required: Supabase SERVICE ROLE key (not the anon/public key). Found in
# Supabase dashboard -> Project Settings -> API. Server-side only -- this
# key bypasses Row Level Security, so it must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Required: shared password for the access gate (api/auth-check.js). Anyone
# with this password can use the app and burn Gemini quota, so keep it
# private -- this is not full auth, just a lightweight gate since the
# deployed URL is public.
ACCESS_PASSWORD=
